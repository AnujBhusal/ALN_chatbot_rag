# Database Configuration
DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rag

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Pinecone Configuration
PINECONE_API_KEY=
PINECONE_INDEX=documents
PINECONE_REGION=us-east-1
PINECONE_CLOUD=aws
PINECONE_NAMESPACE=default

# Vector Store Settings
VECTOR_STORE=pinecone

# Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=microsoft/DialoGPT-medium

# Hugging Face API Key (Optional - get from https://huggingface.co/settings/tokens)
# HF_API_KEY=your_huggingface_api_key_here

# ====== LOCAL DEVELOPMENT MODE ======
# These settings enable folder-based PDF ingestion for local development
# 
# LOCAL_MODE: Set to 'true' to enable local folder ingestion (auto-detected if not on Render)
# ENABLE_FOLDER_INGESTION: Set to 'true' to auto-ingest PDFs from ./data/pdfs on startup
#
# In LOCAL_MODE:
#   - PDFs in ./data/pdfs folder are automatically processed on server startup
#   - No need to upload via HTTP - just drop PDFs in ./data/pdfs
#   - Perfect for development and testing locally
#
# In PRODUCTION (on Render/Vercel):
#   - Disable with LOCAL_MODE=false and ENABLE_FOLDER_INGESTION=false
#   - Use HTTP upload endpoints instead for controlled uploads

LOCAL_MODE=false
ENABLE_FOLDER_INGESTION=true