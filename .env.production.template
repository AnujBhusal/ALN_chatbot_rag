# Production Environment Configuration
# Copy this to .env.production and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DB_URL=postgresql://postgres:postgres@localhost:5432/rag

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ============================================
# QDRANT VECTOR DATABASE
# ============================================
QDRANT_URL=http://localhost:6333

# ============================================
# LLM CONFIGURATION
# Choose ONE option below and set others to false
# ============================================

# Option 1: Groq API (RECOMMENDED - Free, Fast)
# Get key from: https://console.groq.com/keys
USE_GROQ=true
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768

# Option 2: HuggingFace API
# Get token from: https://huggingface.co/settings/tokens
USE_HF=false
HF_API_KEY=

# Option 3: Ollama (Self-hosted locally)
# Requires Ollama running on your server
USE_OLLAMA=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Fallback for when all APIs are down
USE_FALLBACK=true

# ============================================
# COHERE API (DEPRECATED - Set to false)
# ============================================
USE_COHERE=false
COHERE_API_KEY=

# ============================================
# EMBEDDINGS CONFIGURATION
# ============================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Server settings
API_HOST=0.0.0.0
API_PORT=8000
ENV=production
DEBUG=false

# Frontend URL for CORS
FRONTEND_URL=https://your-frontend-domain.com

# Chunking settings
CHUNK_SIZE=600
CHUNK_OVERLAP=80

# ============================================
# SESSION & MEMORY
# ============================================
SESSION_TIMEOUT=3600  # 1 hour in seconds
MAX_MESSAGES_IN_MEMORY=50

# ============================================
# RATE LIMITING (Optional)
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# ============================================
# MONITORING & LOGGING (Optional)
# ============================================
LOG_LEVEL=INFO
SENTRY_DSN=

# ============================================
# DEPLOYMENT PLATFORM SPECIFIC
# ============================================

# For Fly.io
FLY_APP_NAME=aln-chatbot
FLY_REGION=dfw

# For Railway
RAILWAY_ENVIRONMENT=production

# For Render
RENDER_EXTERNAL_URL=

# ============================================
# SECURITY (Important for Production)
# ============================================
# Add a secret key for session management
SECRET_KEY=your-super-secret-key-change-this

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# ============================================
# OPTIONAL: Email Notifications
# ============================================
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=admin@example.com
